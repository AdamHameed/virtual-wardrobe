VC_APP_NAME=Virtual Closet API
VC_APP_ENV=development
VC_DEBUG=true
VC_API_V1_PREFIX=/api/v1
VC_DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/virtual_closet
VC_CORS_ORIGINS=http://localhost:3000
VC_MEDIA_ROOT=media
VC_MEDIA_URL=/media
VC_MAX_UPLOAD_SIZE_MB=10
VC_SECRET_KEY=change-me-in-production
VC_ACCESS_TOKEN_EXPIRE_MINUTES=60
VC_JWT_ALGORITHM=HS256
